# Twilio credentials (get from twilio.com — free trial works)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+61200000000

# Your publicly reachable base URL for Twilio webhooks
# Use ngrok for local dev: ngrok http 8000
PUBLIC_BASE_URL=https://your-ngrok-url.ngrok.io

# Database
DATABASE_URL=sqlite:///./pontosense.db

# Escalation timeout in seconds
ESCALATION_TIMEOUT_SECONDS=50

# Set to true to enable the "Simulate Press 1" button on the dashboard
DEMO_MODE=true
